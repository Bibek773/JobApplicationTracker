{
  "info": {
    "name": "Job Application Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "REST API collection for the Job Application Tracker. Endpoints to be implemented."
  },
  "item": [
    {
      "name": "List Applications",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/applications",
        "description": "GET /api/applications - returns paginated list. Query params: ?status=Applied&search=Google&page=1&limit=10"
      }
    },
    {
      "name": "Get Application by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/applications/:id",
        "description": "GET /api/applications/:id - returns a single application"
      }
    },
    {
      "name": "Create Application",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/applications",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"companyName\": \"Example Corp\",\n  \"jobTitle\": \"Software Intern\",\n  \"jobType\": \"Internship\",\n  \"status\": \"Applied\",\n  \"appliedDate\": \"2026-06-17\",\n  \"notes\": \"Applied via company website\"\n}"
        },
        "description": "POST /api/applications - creates a new application"
      }
    },
    {
      "name": "Update Application",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/applications/:id",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Interviewing\"\n}"
        },
        "description": "PATCH /api/applications/:id - partially updates an application"
      }
    },
    {
      "name": "Delete Application",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/applications/:id",
        "description": "DELETE /api/applications/:id - deletes an application"
      }
    },
    {
      "name": "Filter Applications by Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/applications?status=Applied",
        "description": "GET /api/applications?status=Applied - filter by status"
      }
    },
    {
      "name": "Search Applications",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/applications?search=Google",
        "description": "GET /api/applications?search=Google - search by company or job title"
      }
    }
  ]
}
